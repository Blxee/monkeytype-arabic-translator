{
  "manifest_version": 3,
  "name": "Monkeytype Arabic Translator",
  "version": "1.0.0",
  "description": "Shows an Arabic translation for the active Monkeytype word in a compact overlay above it.",
  "host_permissions": [
    "https://monkeytype.com/*",
    "https://api.mymemory.translated.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://monkeytype.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}